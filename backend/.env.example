# Database — add your Railway PostgreSQL URL here
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Attio API key (from Attio → Settings → API)
ATTIO_API_KEY=your_attio_api_key_here

# Anthropic API key (for the AI assistant mode)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-railway-app.up.railway.app

# Environment
NODE_ENV=production
PORT=3001
